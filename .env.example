# ─────────────────────────────────────────────────────────────────────────────
# Gateway Nacional — exemplo de variáveis de ambiente
# Copie para `.env` e ajuste. O docker-compose.yml e o Spring Boot leem estas
# variáveis; valores ausentes caem nos defaults definidos no application.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Histórico Veicular Premium (orquestração híbrida) ────────────────────────
# Com a chave configurada, o gateway consome a API premium oficial em
# milissegundos. Sem a chave, o client premium curto-circuita e a malha de
# scrapers gratuitos (FlareSolverr/Jsoup) assume como fallback de resiliência.
GATEWAY_OLHONOCARRO_KEY=
GATEWAY_CHECKAUTO_KEY=
# Base-URLs (opcional — sobrescreva apenas para mirrors / sandbox):
# GATEWAY_HISTORICO_OLHONOCARRO_URL=https://api.olhonocarro.com.br
# GATEWAY_HISTORICO_CHECKAUTO_URL=https://api.checkauto.com.br

# ── Motor de depreciação automática por risco ────────────────────────────────
# Redutor aplicado sobre o preço médio de mercado quando o histórico aponta
# risco. Clampeado à faixa mandatória [0.20, 0.30] no boot.
GATEWAY_VEICULAR_RISCO_REDUTOR_MEDIO=0.20
GATEWAY_VEICULAR_RISCO_REDUTOR_ALTO=0.30

# ── Sidecars de resiliência (já existentes) ──────────────────────────────────
# FlareSolverr — necessário para os scrapers gratuitos contornarem Cloudflare.
GATEWAY_FLARESOLVERR_URL=
# SISAB sidecar (Python + Selenium) — necessário para /api/v1/saude/sisab/*.
GATEWAY_SISAB_SIDECAR_URL=
